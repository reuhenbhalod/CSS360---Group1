# Copy this file to `.env` and fill in the values you have.
# Any key left blank causes that source to return ok:false with a clear
# error message; the rest of the dashboard still works.

# Foursquare Places v3 — https://foursquare.com/developers/
FOURSQUARE_API_KEY=

# GNews — https://gnews.io/
GNEWS_API_KEY=

# The Guardian Open Platform — https://open-platform.theguardian.com/
GUARDIAN_API_KEY=

# Reddit needs no key for read-only requests, but a descriptive User-Agent
# is required by their API rules. Override the default if you like.
REDDIT_USER_AGENT=goodeats/0.5 (class project)

# Search center — defaults to downtown Bothell, WA if unset.
GOODEATS_LAT=47.7623
GOODEATS_LON=-122.2054
GOODEATS_RADIUS_M=2000
